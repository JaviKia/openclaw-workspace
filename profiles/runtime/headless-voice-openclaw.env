# Headless voice runtime profile, closer to real use through the OpenClaw backend.
# Reuses the same sample-based audio path, but swaps the echo backend for gateway-backed responses.

OPENCLAW_RUNTIME_REAL_AUDIO=1
OPENCLAW_RUNTIME_AUDIO_BACKEND=ffmpeg
OPENCLAW_RUNTIME_AUDIO_INPUT_FORMAT=file
OPENCLAW_RUNTIME_SAMPLE_DIR=/data/.openclaw/workspace/fixtures/runtime-audio
OPENCLAW_RUNTIME_AUDIO_RATE=16000
OPENCLAW_RUNTIME_AUDIO_CHANNELS=1
OPENCLAW_RUNTIME_AUDIO_POST_END_WAIT_MS=8000
OPENCLAW_RUNTIME_FINAL_WAIT_MS=60000

OPENCLAW_RUNTIME_REAL_STT=1
OPENCLAW_RUNTIME_STT_LANG=es
# Optional tuning hooks:
# OPENCLAW_RUNTIME_STT_FFMPEG_FILTER=highpass=f=120,lowpass=f=3800,loudnorm
# OPENCLAW_RUNTIME_STT_TEXT_REPLACEMENTS=from=>to||from2=>to2

OPENCLAW_RUNTIME_REAL_BACKEND=1
OPENCLAW_RUNTIME_OPENCLAW_BIN=/data/.npm-global/bin/openclaw
OPENCLAW_RUNTIME_SESSION_KEY=agent:main:main
# Optional if you ever need to point at a different gateway:
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=

OPENCLAW_RUNTIME_REAL_TTS=1
OPENCLAW_RUNTIME_TTS_VOICE=en-US-BrianMultilingualNeural

OPENCLAW_RUNTIME_REAL_PLAYBACK=1
